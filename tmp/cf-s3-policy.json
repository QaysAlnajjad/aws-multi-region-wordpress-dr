{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCloudFrontDistributionsReadOnly",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudfront.amazonaws.com"
      },
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::wordpress-media-prod-200/*",
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": [
            "arn:aws:cloudfront::127214183643:distribution/E2VWM462UN7OYJ",
            "arn:aws:cloudfront::127214183643:distribution/E1S0VI6KKVL13N"
          ]
        }
      }
    }
  ]
}
